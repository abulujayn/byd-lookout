<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/bg_surface">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_delete"
                android:contentDescription="Reset"
                app:tint="@color/status_error" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reset Data"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wipe accumulated data by category"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Warning banner -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_elevated"
            app:cardCornerRadius="10dp"
            app:strokeColor="@color/status_error"
            app:strokeWidth="1dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠ This cannot be undone. Recordings, trips, and battery history will be permanently deleted."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:padding="12dp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Category checkboxes -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetTrips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trips"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trip history, routes, weekly/monthly rollups"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetSocHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SoC &amp; 12V history"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SoC samples, charging sessions, voltage logs"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetSoh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SoH calibration"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Re-detects nominal capacity, re-seeds estimate from BMS"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetAbrpToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ABRP token"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Disables ABRP telemetry until re-paired"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetBydCloud"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BYD Cloud credentials"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Username, login key, VIN — re-login required"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetMediaRecordings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recordings (videos)"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="All MP4s in the recordings folder"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetMediaSurveillance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sentry events"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Surveillance event clips and JSON sidecars"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetMediaProximity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Proximity recordings"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Radar-triggered event MP4s"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cbResetMediaTrips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trip telemetry files"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Per-trip JSON telemetry on disk"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="14dp" />

        <!-- Quick toggle row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetSelectAll"
                style="@style/Widget.Overdrive.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Select all"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResetClearAll"
                style="@style/Widget.Overdrive.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clear"
                android:layout_marginStart="8dp"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
